# Saki data location (NAS / local mount)
SAKI_DATA_ROOT=/mnt/saki/inspection_results

# Model artifacts
MODEL_DIR=./checkpoints

# RAG / vector store
CHROMA_PERSIST_DIR=./chroma_db

# LLM (local)
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5:14b-instruct
LLM_BASE_URL=http://localhost:11434

# Serving
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
